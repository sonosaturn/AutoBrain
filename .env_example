# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vault Paths (Use absolute paths or relative to project root)
# Example: C:/Users/YourName/Documents/my_vault
VAULT_PATH=path/to/your/main/vault
CONVO_VAULT_PATH=path/to/your/conversation/vault

# EMAIL CONFIGURATION (For Jarvis Email Tool)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_IMAP_HOST=imap.gmail.com

# Optional: Spotify Configuration
# SPOTIPY_CLIENT_ID=...
# SPOTIPY_CLIENT_SECRET=...
